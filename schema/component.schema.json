{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/lyon-industries/component-intelligence/main/schema/component.schema.json",
  "title": "Component intelligence record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "identity",
    "classification",
    "sources",
    "electrical",
    "package",
    "cad",
    "assembly",
    "validation",
    "rights"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "schema_version": { "const": "0.2.0" },
    "id": { "type": "string", "pattern": "^component:[a-z0-9-]+:.+$" },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manufacturer", "manufacturer_slug", "mpn", "series"],
      "properties": {
        "manufacturer": { "type": "string", "minLength": 1 },
        "manufacturer_slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "mpn": { "type": "string", "minLength": 1 },
        "series": { "type": "string", "minLength": 1 },
        "orderable": { "type": ["boolean", "null"] },
        "orderable_checked_on": { "type": ["string", "null"], "format": "date" }
      }
    },
    "classification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category", "function"],
      "properties": {
        "category": { "type": "string", "minLength": 1 },
        "function": { "type": "string", "minLength": 1 },
        "keywords": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/source" }
    },
    "electrical": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pins", "ratings", "internally_common_terminal_groups"],
      "properties": {
        "pins": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/pin" }
        },
        "ratings": {
          "type": "array",
          "items": { "$ref": "#/$defs/rating" }
        },
        "internally_common_terminal_groups": {
          "type": "array",
          "items": {
            "type": "array",
            "minItems": 2,
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          }
        }
      }
    },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "mounting", "pin_count", "body_dimensions_mm", "land_pattern"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "manufacturer_code": { "type": ["string", "null"] },
        "mounting": { "enum": ["surface-mount", "through-hole", "mixed"] },
        "pin_count": { "type": "integer", "minimum": 1 },
        "pitch_mm": { "type": ["number", "null"], "exclusiveMinimum": 0 },
        "body_dimensions_mm": {
          "type": "object",
          "additionalProperties": {
            "type": ["number", "object"],
            "properties": {
              "min": { "type": "number" },
              "typ": { "type": "number" },
              "max": { "type": "number" }
            },
            "additionalProperties": false,
            "minProperties": 1
          }
        },
        "land_pattern": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "source_id", "locator", "pad_count"],
          "properties": {
            "status": {
              "enum": ["manufacturer-dimensioned", "cross-checked", "unknown"]
            },
            "source_id": { "type": "string", "minLength": 1 },
            "locator": { "type": "string", "minLength": 1 },
            "pad_count": { "type": "integer", "minimum": 1 },
            "dimensions_mm": {
              "type": "object",
              "additionalProperties": { "type": "number" }
            },
            "pads": {
              "type": "array",
              "items": { "$ref": "#/$defs/pad" }
            },
            "coordinate_convention": { "type": ["string", "null"] }
          }
        }
      }
    },
    "cad": {
      "type": "object",
      "additionalProperties": false,
      "required": ["symbol", "footprint", "step_model"],
      "properties": {
        "symbol": { "$ref": "#/$defs/cadAsset" },
        "footprint": { "$ref": "#/$defs/cadAsset" },
        "step_model": { "$ref": "#/$defs/cadAsset" }
      }
    },
    "assembly": {
      "type": "object",
      "additionalProperties": false,
      "required": ["process", "packing", "orientation"],
      "properties": {
        "process": { "type": "string", "minLength": 1 },
        "packing": {
          "type": "object",
          "additionalProperties": false,
          "required": ["method", "quantity"],
          "properties": {
            "method": { "type": ["string", "null"] },
            "quantity": { "type": ["integer", "null"], "minimum": 1 },
            "source_id": { "type": ["string", "null"] },
            "locator": { "type": ["string", "null"] }
          }
        },
        "orientation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "description"],
          "properties": {
            "status": { "enum": ["documented", "partial", "unknown"] },
            "description": { "type": "string", "minLength": 1 },
            "source_id": { "type": ["string", "null"] },
            "locator": { "type": ["string", "null"] }
          }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_state",
        "physical_state",
        "release_state",
        "reviewed_on",
        "checks",
        "known_issues"
      ],
      "properties": {
        "evidence_state": {
          "enum": ["captured", "extracted", "cross-checked", "physically-verified"]
        },
        "physical_state": { "enum": ["not-tested", "part-tested", "assembly-tested"] },
        "release_state": {
          "enum": ["reference-only", "candidate", "agent-ready", "production-approved"]
        },
        "reviewed_on": { "type": "string", "format": "date" },
        "checks": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/check" }
        },
        "known_issues": {
          "type": "array",
          "items": { "$ref": "#/$defs/knownIssue" }
        }
      }
    },
    "rights": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository_content_license",
        "source_files_redistributed",
        "normalized_record_origin",
        "source_rights_status"
      ],
      "properties": {
        "repository_content_license": { "const": "Apache-2.0" },
        "source_files_redistributed": { "const": false },
        "normalized_record_origin": { "type": "string", "minLength": 1 },
        "source_rights_status": { "enum": ["linked-only", "review-required", "cleared"] }
      }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "publisher",
        "title",
        "url",
        "published_date",
        "retrieved_at",
        "retrieval_status",
        "sha256",
        "page_count",
        "redistributed",
        "locators"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": {
          "enum": [
            "datasheet",
            "package-drawing",
            "product-page",
            "application-note",
            "errata",
            "reference-design",
            "standard",
            "test"
          ]
        },
        "publisher": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri", "pattern": "^https://" },
        "document_number": { "type": ["string", "null"] },
        "revision": { "type": ["string", "null"] },
        "published_date": { "type": ["string", "null"], "format": "date" },
        "retrieved_at": { "type": "string", "format": "date-time" },
        "retrieval_status": {
          "enum": ["captured-and-hashed", "browser-reviewed-byte-capture-blocked"]
        },
        "sha256": {
          "type": ["string", "null"],
          "pattern": "^[0-9a-f]{64}$"
        },
        "byte_size": { "type": ["integer", "null"], "minimum": 1 },
        "page_count": { "type": ["integer", "null"], "minimum": 1 },
        "redistributed": { "const": false },
        "locators": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["page", "label"],
            "properties": {
              "page": { "type": "integer", "minimum": 1 },
              "label": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "pin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["number", "name", "function", "source_id", "locator"],
      "properties": {
        "number": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "function": { "type": "string", "minLength": 1 },
        "electrical_type": {
          "enum": [
            "input",
            "output",
            "bidirectional",
            "power-input",
            "power-output",
            "ground",
            "passive",
            "open-collector",
            "open-drain",
            "no-connect",
            "mechanical"
          ]
        },
        "source_id": { "type": "string", "minLength": 1 },
        "locator": { "type": "string", "minLength": 1 }
      }
    },
    "rating": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "value", "unit", "qualifier", "source_id", "locator"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "value": {
          "oneOf": [
            { "type": "number" },
            {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "min": { "type": "number" },
                "typ": { "type": "number" },
                "max": { "type": "number" },
                "tolerance": { "type": "number" }
              },
              "minProperties": 1
            }
          ]
        },
        "unit": { "type": "string", "minLength": 1 },
        "boundary": {
          "enum": [
            "absolute-maximum",
            "recommended-operating",
            "characteristic",
            "application-dependent"
          ]
        },
        "qualifier": { "type": "string", "minLength": 1 },
        "source_id": { "type": "string", "minLength": 1 },
        "locator": { "type": "string", "minLength": 1 }
      }
    },
    "pad": {
      "type": "object",
      "additionalProperties": false,
      "required": ["number", "x_mm", "y_mm", "width_mm", "height_mm"],
      "properties": {
        "number": { "type": "string", "minLength": 1 },
        "x_mm": { "type": "number" },
        "y_mm": { "type": "number" },
        "width_mm": { "type": "number", "exclusiveMinimum": 0 },
        "height_mm": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "cadAsset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "path", "manufacturing_use", "provenance"],
      "properties": {
        "status": {
          "enum": [
            "preview-only",
            "reference-identified",
            "not-included",
            "not-applicable",
            "cross-checked"
          ]
        },
        "path": { "type": ["string", "null"] },
        "format": { "type": ["string", "null"], "minLength": 1 },
        "sha256": {
          "type": ["string", "null"],
          "pattern": "^[0-9a-f]{64}$"
        },
        "tool_version": { "type": ["string", "null"], "minLength": 1 },
        "manufacturing_use": { "type": "boolean" },
        "provenance": { "type": "string", "minLength": 1 },
        "reference": { "type": ["string", "null"] },
        "reason": { "type": ["string", "null"] }
      }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "status", "method", "date"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "status": { "enum": ["pass", "open", "not-applicable"] },
        "method": { "type": "string", "minLength": 1 },
        "date": { "type": "string", "format": "date" }
      }
    },
    "knownIssue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["severity", "scope", "summary", "status"],
      "properties": {
        "severity": { "enum": ["note", "design-risk", "fabrication-stop"] },
        "scope": { "enum": ["component", "integration-example", "data-pipeline"] },
        "summary": { "type": "string", "minLength": 1 },
        "status": { "enum": ["documented", "open", "resolved-in-example"] }
      }
    }
  }
}
